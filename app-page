<!-- DIGITAL STORE -->
<div class="app-page" id="ap-store">
  <div class="app-page-title">🛍️ Digital Store</div>

  <!-- Search -->
  <div class="app-svc-search-wrap">
    <span class="app-svc-search-icon">🔍</span>
    <input type="text" class="app-svc-search" id="storeSearch" placeholder="Search software, ebooks, templates..." oninput="filterStoreProducts()">
  </div>

  <div class="svc-results-count" id="storeCount">Loading products...</div>
  <div class="app-svc-grid" id="storeGrid">
    <div style="grid-column:1/-1;text-align:center;padding:2rem;color:var(--text3)">
      <div class="spinner" style="margin:0 auto .5rem"></div>Loading...
    </div>
  </div>

  <!-- Buy Modal (inline) -->
  <div class="modal-overlay" id="storeModal">
    <div class="modal" style="max-width:440px">
      <div class="modal-head">
        <h3 id="storeModalTitle">Confirm Purchase</h3>
        <button class="close-x" onclick="closeModal('storeModal')">✕</button>
      </div>
      <div class="modal-body">
        <div style="background:var(--bg3);border-radius:10px;padding:1rem;margin-bottom:1rem">
          <div style="display:flex;justify-content:space-between;font-size:.84rem;margin-bottom:.4rem">
            <span style="color:var(--text2)">Product</span>
            <span id="storeModalName" style="font-weight:600">–</span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:.84rem;margin-bottom:.4rem">
            <span style="color:var(--text2)">Price</span>
            <span id="storeModalPrice" style="font-weight:700;color:var(--green)">–</span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:.84rem">
            <span style="color:var(--text2)">Your Balance</span>
            <span id="storeModalBal" style="font-weight:600">–</span>
          </div>
        </div>
        <button class="fbtn" id="storeBuyBtn" onclick="confirmStoreBuy()">🛒 Buy Now</button>
        <div class="smsg" id="storeMsg"></div>
      </div>
    </div>
  </div>
</div>
